# Obsidian Vault
OBSIDIAN_VAULT_PATH=C:\Users\YourName\path\to\obsidian\vault
OBSIDIAN_MEETINGS_SUBFOLDER=Meetings

# Arc Directories (will be created on first run)
ARC_INTAKE_DIR=C:\Users\YourName\Desktop\arc\intake
ARC_TEMP_DIR=C:\Users\YourName\Desktop\arc\temp
ARC_DB_PATH=C:\Users\YourName\Desktop\arc\arc.db

# Server
ARC_SERVER_PORT=8000

# HuggingFace (required for pyannote — accept terms at huggingface.co/pyannote/speaker-diarization-3.1)
HF_TOKEN=your_hf_token_here

# Transcription provider: llamacpp (default, local), groq, or gemini
TRANSCRIPTION_PROVIDER=llamacpp

# whisper-cli.exe paths (used when TRANSCRIPTION_PROVIDER=llamacpp)
WHISPER_CLI_PATH=C:\llama\whisper\whisper-cli.exe
WHISPER_MODEL_PATH=C:\llama\whisper\models\ggml-large-v3-turbo.bin
WHISPER_LANGUAGE=hi

# llama-server for note generation (Gemma 4 E4B)
LLAMACPP_HOST=http://localhost:8081

# DEPRECATED: note_generator.py now uses llama-server (LLAMACPP_HOST) — Ollama no longer used
# OLLAMA_MODEL=gemma3:4b
# OLLAMA_HOST=http://localhost:11434

# Groq fallback (TRANSCRIPTION_PROVIDER=groq)
GROQ_API_KEY=your_groq_api_key_here
# Gemini fallback for files >20MB (TRANSCRIPTION_PROVIDER=gemini, get key at aistudio.google.com)
GOOGLE_API_KEY=your_google_api_key_here
